{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MidoriVPN",
  "version": "1.0.2",
  "identifier": "org.astian.midorivpn",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MidoriVPN",
        "width": 460,
        "height": 700,
        "resizable": false,
        "visible": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' tauri: asset:",
        "connect-src": "'self' ipc: http://ipc.localhost http://127.0.0.1:7071",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: data: blob:",
        "font-src": "'self'",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'"
      }
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "rpm", "dmg", "app", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../agent/target/release/agent": "agent",
      "polkit/org.astian.midorivpn.policy": "polkit/org.astian.midorivpn.policy",
      "../packaging/apparmor/usr.local.bin.midorivpn-agent": "apparmor/usr.local.bin.midorivpn-agent",
      "../packaging/selinux/midorivpn.te": "selinux/midorivpn.te",
      "../packaging/selinux/midorivpn.fc": "selinux/midorivpn.fc",
      "../packaging/autostart/midorivpn.desktop": "autostart/midorivpn.desktop",
      "../packaging/launcher/midorivpn.desktop": "launcher/midorivpn.desktop",
      "icons/32x32.png": "icons/32x32.png",
      "icons/128x128.png": "icons/128x128.png",
      "icons/128x128@2x.png": "icons/128x128@2x.png"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libssl3", "policykit-1"],
        "files": {
          "/usr/share/polkit-1/actions/org.astian.midorivpn.policy": "polkit/org.astian.midorivpn.policy",
          "/etc/apparmor.d/usr.local.bin.midorivpn-agent": "../packaging/apparmor/usr.local.bin.midorivpn-agent",
          "/usr/share/midorivpn/selinux/midorivpn.te": "../packaging/selinux/midorivpn.te",
          "/usr/share/midorivpn/selinux/midorivpn.fc": "../packaging/selinux/midorivpn.fc"
        },
        "postInstallScript": "../packaging/maintainer/postinst",
        "preRemoveScript": "../packaging/maintainer/prerm"
      },
      "rpm": {
        "depends": [],
        "files": {
          "/usr/share/polkit-1/actions/org.astian.midorivpn.policy": "polkit/org.astian.midorivpn.policy",
          "/usr/share/midorivpn/selinux/midorivpn.te": "../packaging/selinux/midorivpn.te",
          "/usr/share/midorivpn/selinux/midorivpn.fc": "../packaging/selinux/midorivpn.fc"
        },
        "postInstallScript": "../packaging/maintainer/postinst",
        "preRemoveScript": "../packaging/maintainer/prerm"
      }
    }
  }
}
