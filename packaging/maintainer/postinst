#!/bin/sh
# Maintainer post-install script for MidoriVPN .deb / .rpm packages.
#
# Responsibilities (each idempotent + best-effort):
#   1. Install the bundled agent to /usr/local/bin/midorivpn-agent so polkit
#      and AppArmor profiles resolve correctly.
#   2. Reload polkit so the new action file becomes available immediately.
#   3. Load the AppArmor profile (in complain mode first run) when the
#      kernel + parser are present.
#   4. Load the SELinux module + fcontext when semodule is present.
#
# Designed to never fail the package install — every step is wrapped in
# `|| true` so an unexpected SELinux/AppArmor configuration does not block
# users from getting the GUI.
set -e

AGENT_BUNDLED="/usr/lib/MidoriVPN/agent"   # Tauri uses productName for the lib dir
# Fallback: some packaging tools lowercase the product name
[ -f "$AGENT_BUNDLED" ] || AGENT_BUNDLED="/usr/lib/midorivpn/agent"
# Fallback: Tauri may use the binary name as the lib dir
[ -f "$AGENT_BUNDLED" ] || AGENT_BUNDLED="/usr/lib/midorivpn-desktop/agent"
AGENT_INSTALL="/usr/local/bin/midorivpn-agent"
APPARMOR_PROFILE="/etc/apparmor.d/usr.local.bin.midorivpn-agent"
APPARMOR_BUNDLED="/usr/lib/MidoriVPN/apparmor/usr.local.bin.midorivpn-agent"
SELINUX_MOD_DIR="/usr/share/midorivpn/selinux"
# Launcher .desktop (no --autostart flag) — shown in GNOME/KDE application menu
DESKTOP_LAUNCHER_SRC="/usr/lib/MidoriVPN/launcher/midorivpn.desktop"
DESKTOP_APPLICATIONS="/usr/share/applications/midorivpn.desktop"
# Autostart .desktop (with --autostart flag) — for ~/.config/autostart via plugin
DESKTOP_SRC="/usr/lib/MidoriVPN/autostart/midorivpn.desktop"
ICON_SRC_32="/usr/lib/MidoriVPN/icons/32x32.png"
ICON_SRC_128="/usr/lib/MidoriVPN/icons/128x128.png"
ICON_SRC_256="/usr/lib/MidoriVPN/icons/128x128@2x.png"

install_root() {
    # Force root ownership for files created by maintainer scripts. Files that
    # come directly from the RPM/DEB payload are already root:root, but these
    # copied compatibility paths should be deterministic too.
    install -o root -g root "$@"
}

ensure_root_owner() {
    [ -e "$1" ] && chown root:root "$1" 2>/dev/null || true
}

# 1. Place the agent where polkit/SELinux expect it.
# Always overwrite so package upgrades replace any previous build (dev or
# packaged). `install` is atomic and preserves the new mtime.
if [ -f "$AGENT_BUNDLED" ]; then
    chmod 0755 "$AGENT_BUNDLED" || true
    install_root -m 0755 "$AGENT_BUNDLED" "$AGENT_INSTALL" || \
        cp -f "$AGENT_BUNDLED" "$AGENT_INSTALL" && chmod 0755 "$AGENT_INSTALL" || true
    ensure_root_owner "$AGENT_INSTALL"
else
    echo "WARNING: midorivpn-agent binary not found at $AGENT_BUNDLED." >&2
fi

# 1b. Stage the AppArmor profile in /etc when not already there (rpm).
if [ -f "$APPARMOR_BUNDLED" ] && [ ! -e "$APPARMOR_PROFILE" ]; then
    install_root -m 0644 "$APPARMOR_BUNDLED" "$APPARMOR_PROFILE" || true
    ensure_root_owner "$APPARMOR_PROFILE"
fi

# 1c. Install XDG icon theme entries (hicolor) so the app appears in launchers.
if [ -f "$ICON_SRC_32" ]; then
    install_root -D -m 0644 "$ICON_SRC_32" /usr/share/icons/hicolor/32x32/apps/midorivpn.png || true
    ensure_root_owner /usr/share/icons/hicolor/32x32/apps/midorivpn.png
fi
if [ -f "$ICON_SRC_128" ]; then
    install_root -D -m 0644 "$ICON_SRC_128" /usr/share/icons/hicolor/128x128/apps/midorivpn.png || true
    ensure_root_owner /usr/share/icons/hicolor/128x128/apps/midorivpn.png
fi
if [ -f "$ICON_SRC_256" ]; then
    install_root -D -m 0644 "$ICON_SRC_256" /usr/share/icons/hicolor/256x256/apps/midorivpn.png || true
    ensure_root_owner /usr/share/icons/hicolor/256x256/apps/midorivpn.png
fi
if command -v gtk-update-icon-cache >/dev/null 2>&1 && [ -d /usr/share/icons/hicolor ]; then
    gtk-update-icon-cache -qf /usr/share/icons/hicolor 2>/dev/null || true
fi

# 1d. Install .desktop entry into /usr/share/applications for GNOME/KDE launchers.
# Prefer the dedicated launcher desktop file (no --autostart); fall back to autostart one.
_DESKTOP_FOR_APPS="${DESKTOP_LAUNCHER_SRC}"
[ -f "$_DESKTOP_FOR_APPS" ] || _DESKTOP_FOR_APPS="${DESKTOP_SRC}"
if [ -f "$_DESKTOP_FOR_APPS" ]; then
    install_root -D -m 0644 "$_DESKTOP_FOR_APPS" "$DESKTOP_APPLICATIONS" || true
    ensure_root_owner "$DESKTOP_APPLICATIONS"
    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database /usr/share/applications 2>/dev/null || true
    fi
fi

# 2. Polkit reload (rules file dropped by package).
if [ -d /run/systemd/system ] && command -v systemctl >/dev/null 2>&1; then
    systemctl reload polkit.service 2>/dev/null || \
    systemctl restart polkit.service 2>/dev/null || true
fi

# 3. AppArmor — load profile in complain mode first, switch to enforce after
#    the user has connected at least once without denials.
if command -v apparmor_parser >/dev/null 2>&1 && [ -f "$APPARMOR_PROFILE" ]; then
    apparmor_parser -r "$APPARMOR_PROFILE" 2>/dev/null || true
    if command -v aa-complain >/dev/null 2>&1; then
        aa-complain "$APPARMOR_PROFILE" >/dev/null 2>&1 || true
    fi
fi

# 4. SELinux module install when targeted policy is in use.
if command -v semodule >/dev/null 2>&1 && [ -d "$SELINUX_MOD_DIR" ]; then
    (
        cd "$SELINUX_MOD_DIR" && \
        checkmodule -M -m -o midorivpn.mod midorivpn.te && \
        semodule_package -o midorivpn.pp -m midorivpn.mod -f midorivpn.fc && \
        semodule -i midorivpn.pp
    ) >/dev/null 2>&1 || true

    if command -v restorecon >/dev/null 2>&1 && [ -e "$AGENT_INSTALL" ]; then
        restorecon -v "$AGENT_INSTALL" >/dev/null 2>&1 || true
    fi
fi

exit 0
