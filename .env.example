# MidoriVPN Desktop — example environment variables.
# Copy this to .env (dev) or .env.production (prod) and adjust values.
# DO NOT commit .env or .env.production — they are gitignored.

# Origin the agent's RPC server will accept.
# Dev (Vite):        http://localhost:1420
# Production (Tauri): tauri://localhost
AGENT_ALLOWED_ORIGIN=tauri://localhost

# Same value exposed to Vite so Vue can build the correct EventSource URL.
VITE_AGENT_ORIGIN=tauri://localhost
