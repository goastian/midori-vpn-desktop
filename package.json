{
  "name": "midorivpn-desktop",
  "version": "1.1.2",
  "private": true,
  "description": "",
  "main": "index.js",
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "pinia": "^3.0.4",
    "vue": "3.5.35",
    "vue-i18n": "11.4.4",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tauri-apps/cli": "2.11.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "4.1.8",
    "@vue/test-utils": "^2.4.10",
    "eslint": "10.4.1",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.6.0",
    "happy-dom": "^20.10.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "vue-tsc": "^3.3.3"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "bash scripts/tauri-build.sh",
    "appimage:build:local": "bash scripts/build-local-appimage.sh",
    "appimage:run:local": "bash scripts/run-local-appimage.sh",
    "verify:tauri-resources": "node scripts/verify-tauri-resources.mjs",
    "security:tools": "bash scripts/install-security-tools.sh",
    "security:audit": "bash scripts/cargo-audit.sh && bash scripts/govulncheck.sh && bash scripts/npm-audit.sh",
    "security:audit:npm": "bash scripts/npm-audit.sh",
    "build-agent": "bash scripts/build-agent.sh all",
    "build-agent:host": "bash scripts/build-agent.sh host"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goastian/midorivpn-desktop.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/goastian/midorivpn-desktop/issues"
  },
  "homepage": "https://github.com/goastian/midorivpn-desktop#readme"
}
